{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "hooks:install": "git config core.hooksPath frontend/.husky/_",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --cache --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "validate": "bun run lint && bun run typecheck",
    "precommit": "bun run validate",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@tanstack/react-query": "^5.96.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-toastify": "^11.0.5",
    "react-virtuoso": "^4.18.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
